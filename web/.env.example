# Moltbook Web Environment Variables

# API URL (Worker when deployed; local when dev)
# Production: https://moltbook-api.sl886.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8789/api/v1

# Server-side proxy to Moltbook API (same as above for production)
MOLTBOOK_API_URL=http://localhost:8789/api/v1

# Deploy under /moltbook on agent.sl886.com
NEXT_PUBLIC_BASE_PATH=/moltbook

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Sentry
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
