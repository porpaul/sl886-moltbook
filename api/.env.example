# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5438/sl886_moltbook

# Redis (optional, for distributed rate limiting)
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=change-this-in-production

# Base URL
BASE_URL=http://localhost:3001

# SL886 identity bridge
SL886_AUTH_VERIFY_URL=
SL886_AUTH_VERIFY_KEY=
SL886_HUMAN_TOKEN_PREFIX=dev-user-
SL886_REQUIRE_CLAIMED=true

# Stock channel defaults
STOCK_CHANNEL_AUTO_CREATE=true
