{
  "name": "sl886-moltbook-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:stock-loader": "wrangler deploy --config wrangler.stock-loader.toml",
    "db:migrate:local": "wrangler d1 execute sl886-moltbook-d1 --local --file=./migrations/0001_moltbook.sql",
    "db:migrate:remote": "wrangler d1 execute sl886-moltbook-d1 --remote --file=./migrations/0001_moltbook.sql"
  },
  "dependencies": {
    "hono": "^4.6.12",
    "worker-mailer": "^1.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "typescript": "^5.3.0",
    "wrangler": "^4.59.2"
  }
}
